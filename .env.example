# =====================================================================
# Osyanificación Plugin Moodle — Variables de entorno (template)
# =====================================================================
# CÓMO USAR:
#   1. cp .env.example .env
#   2. Cambiá los valores marcados con CAMBIAME_ por contraseñas reales
#   3. .env está en .gitignore — NO se commitea
#   4. docker-compose up -d
# =====================================================================

# ---------------------------------------------------------------------
# MariaDB — base de datos
# ---------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=CAMBIAME_root_password_largo_y_seguro
MARIADB_USER=bn_moodle
MARIADB_PASSWORD=CAMBIAME_moodle_db_password
MARIADB_DATABASE=bitnami_moodle

# ---------------------------------------------------------------------
# Moodle — admin inicial
# ---------------------------------------------------------------------
# Usuario admin que vas a usar para entrar a Moodle local
MOODLE_USERNAME=admin
MOODLE_PASSWORD=CAMBIAME_admin_password_minimo_8_caracteres_con_mayuscula_numero_simbolo

# Email del admin (no necesita ser real — Mailhog captura todo)
MOODLE_EMAIL=admin@osyanificacion.local

# Nombre del sitio que verás en el header
MOODLE_SITE_NAME="Osyanificacion Demo"
